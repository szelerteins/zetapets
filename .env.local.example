# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
# Crear nueva aplicación → copiar "Access Token"
# Usar el token de TEST primero, luego reemplazar por PRODUCCIÓN
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# ── URL pública de la app ─────────────────────────────────────────────────────
# En local con ngrok: https://xxxx.ngrok-free.app
# En producción: https://zetapets.vercel.app
NEXT_PUBLIC_APP_URL=https://zetapets.vercel.app

# ── Gmail (Nodemailer) ────────────────────────────────────────────────────────
# Cómo obtener App Password: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
GMAIL_USER=zetapets.ar@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
